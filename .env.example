# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# JWT Secret for auth tokens
JWT_SECRET=your_jwt_secret_here

# Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/microwave_queue

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Server Port
PORT=3001

# Queue Configuration
QUEUE_START_HOUR=12
QUEUE_START_MINUTE=0
QUEUE_END_HOUR=12
QUEUE_END_MINUTE=45
FOOD_HEAT_MINUTES=3
